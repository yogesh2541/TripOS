// TripCraft — CRM-extended schema (Phase 1)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  MANUAL
  INSTAGRAM
  REFERRAL
  WEBSITE
  WHATSAPP
  GOOGLE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  REQUIREMENT_UNDERSTOOD
  QUOTED
  FOLLOW_UP
  WON
  LOST
}

enum TravelerRelationship {
  SELF
  SPOUSE
  CHILD
  PARENT
  SIBLING
  FRIEND
  COLLEAGUE
  OTHER
}

enum TripStatus {
  PLANNING
  QUOTED
  BOOKED
  VENDOR_CONFIRMATION_PENDING
  PARTIALLY_CONFIRMED
  READY_TO_TRAVEL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL
}

enum PaymentLinkStatus {
  CREATED
  PAID
  CANCELLED
  EXPIRED
}

enum ActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  STATUS_CHANGED
  TRIP_CREATED
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_ACCEPTED
  BOOKING_CREATED
  PAYMENT_RECORDED
  CUSTOM
  // Operations / vendor lifecycle
  VENDOR_ASSIGNED
  VENDOR_CONFIRMED
  VENDOR_CANCELLED
  VOUCHER_GENERATED
  VOUCHER_SENT
  VENDOR_PAYMENT_ADDED
  OPS_TASK_CREATED
  OPS_TASK_COMPLETED
  TRIP_READY
  TRIP_STARTED
  TRIP_COMPLETED
  // WhatsApp communication
  WHATSAPP_INBOUND
  WHATSAPP_OUTBOUND
  QUOTE_SENT_WHATSAPP
  INVOICE_SENT_WHATSAPP
  PAYMENT_REMINDER_SENT
  FOLLOW_UP_SENT
  TRIP_REMINDER_SENT
  VOUCHER_SENT_WHATSAPP
}

enum VendorType {
  HOTEL
  TRANSPORT
  DRIVER
  GUIDE
  ACTIVITY
  DMC
  OTHER
}

enum VendorAssignmentCategory {
  HOTEL
  TRANSFER
  SIGHTSEEING
  ACTIVITY
  GUIDE
  FLIGHT
  TRAIN
  OTHER
}

enum VendorAssignmentStatus {
  PENDING
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OperationTaskType {
  HOTEL_CONFIRMATION
  DRIVER_ASSIGNMENT
  PAYMENT_COLLECTION
  VOUCHER_SENT
  DOCUMENT_COLLECTION
  INTERNAL
  OTHER
}

enum OperationTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum OperationTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VendorPaymentMode {
  CASH
  BANK
  UPI
  CARD
  OTHER
}

// Tax invoice domain — designed to be extensible for credit/debit notes,
// vendor billing, multi-rate, TCS/TDS and e-invoicing in later phases.
enum TaxableBasis {
  // Tax computed on the entire invoice value
  FULL_AMOUNT
  // Tax computed only on a service-fee component
  SERVICE_FEE_ONLY
  // Tax computed only on the agency margin (selling - cost)
  MARGIN_ONLY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum InvoiceTaxScheme {
  // 5% concessional (tour operator services, no Input Tax Credit)
  GST_5_NO_ITC
  // 18% regular regime (with ITC)
  GST_18_REGULAR
  // Exempt (e.g. exports, SEZ supplies)
  EXEMPT
}

enum TravelSegmentType {
  FLIGHT
  TRAIN
}

// === WhatsApp Cloud API ===

enum WhatsappDirection {
  INBOUND
  OUTBOUND
}

enum WhatsappStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsappMessageKind {
  TEXT
  TEMPLATE
  DOCUMENT
  IMAGE
  INTERACTIVE
  REACTION
  LOCATION
  UNKNOWN
}

enum WhatsappTemplateCategory {
  PROPOSAL
  INVOICE
  PAYMENT_REMINDER
  FOLLOW_UP
  TRIP_REMINDER
  OPERATIONS
  UTILITY
  MARKETING
  CUSTOM
}

enum WhatsappAutomationTrigger {
  QUOTE_SENT_NO_REPLY_24H
  QUOTE_SENT_NO_REPLY_3D
  QUOTE_SENT_NO_REPLY_7D
  PAYMENT_DUE_T_MINUS_3
  PAYMENT_DUE_TODAY
  PAYMENT_OVERDUE_2D
  TRIP_T_MINUS_7
  TRIP_T_MINUS_1
  TRIP_DEPARTURE_DAY
  TRIP_COMPLETED_THANKS
  INVOICE_ISSUED
}

// === Multi-tenant primitives ===

enum MembershipRole {
  // Full control: agency settings, billing, team, every CRM action.
  OWNER
  // Day-to-day operator: leads, trips, quotes, invoices, WhatsApp.
  // Cannot manage team or change billing.
  STAFF
  // Read-only — useful for accountants, auditors, advisors.
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PlanTier {
  TRIAL
  STARTER
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  // Set on credentials-provider signup. NULL means "passwordless invite
  // pending" or "magic-link / OAuth only" once those are added.
  hashedPassword String?
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships         Membership[]
  sentInvites         Invite[]             @relation("InviteSender")
  passwordResetTokens PasswordResetToken[]

  // Attribution / assignment relations (who in the agency did/owns this).
  // Agency tenancy itself lives on the entity via agencyId; these are
  // nullable because the original creator may have been removed.
  ownedContacts    Contact[]          @relation("ContactOwner")
  ownedTrips       Trip[]             @relation("TripOwner")
  createdInvoices  Invoice[]          @relation("InvoiceCreator")
  sentMessages     WhatsappMessage[]  @relation("WhatsappSender")
  createdTemplates WhatsappTemplate[] @relation("TemplateCreator")
  activities       Activity[]         @relation("ActivityActor")
}

/// Single-use, short-lived password reset token. We store only the SHA-256
/// hash of the token; the raw value lives only in the emailed link, so a DB
/// leak can't be replayed. Expires in 1 hour, burned on use.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// The tenant. Every business-domain row in the system roots up to an
/// Agency via agencyId — that's the single fence for data isolation.
/// One User can belong to many Agencies via Membership (e.g. consultants
/// helping multiple agencies). Agency.slug is used for the future public
/// microsite (/<slug>).
model Agency {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         Membership[]
  invites             Invite[]
  settings            AgencySettings?
  subscription        Subscription?
  invoiceCounters     InvoiceCounter[]
  contacts            Contact[]
  trips               Trip[]
  invoices            Invoice[]
  vendors             Vendor[]
  whatsappMessages    WhatsappMessage[]
  whatsappTemplates   WhatsappTemplate[]
  whatsappAutomations WhatsappAutomationRule[]
  paymentLinks        PaymentLink[]

  @@index([slug])
}

/// User ↔ Agency edge. The `role` here drives every permission check —
/// see [src/lib/auth.ts](src/lib/auth.ts).
model Membership {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId    String
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  role        MembershipRole @default(STAFF)
  // Soft-suspend without losing history (audit trails still resolve).
  suspendedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, agencyId])
  @@index([agencyId, role])
}

/// Pending team invitation. The token is the URL fragment the recipient
/// clicks; it's a long random string, no enumeration risk.
model Invite {
  id          String         @id @default(cuid())
  agencyId    String
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  email       String
  role        MembershipRole @default(STAFF)
  token       String         @unique
  invitedById String
  invitedBy   User           @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Restrict)
  status      InviteStatus   @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@unique([agencyId, email])
  @@index([token])
  @@index([agencyId, status])
}

/// The agency's SaaS subscription to TripCraft itself (distinct from any
/// payment the agency collects from its own customers). One per agency.
/// A fresh agency starts on TRIAL; `trialEndsAt` drives the countdown and
/// the soft-lock. Razorpay Subscriptions fields are populated once the
/// agency upgrades to a paid plan.
model Subscription {
  id       String @id @default(cuid())
  agencyId String @unique
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  plan   PlanTier           @default(TRIAL)
  status SubscriptionStatus @default(TRIALING)

  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean  @default(false)

  // Razorpay Subscriptions linkage (null until the agency pays).
  providerSubId      String? @unique
  providerCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A contact — the permanent person/household the agency works with. The
/// single CRM identity: it carries the inquiry details, billing identity,
/// travellers and the full trip history across however many trips they
/// book over the years. There is no separate "Customer" record — a contact
/// who has booked is simply one whose `convertedAt` is set; the rest are
/// "leads". Status reflects the pipeline of their most recent inquiry.
model Contact {
  id       String  @id @default(cuid())
  agencyId String
  agency   Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  // Owner — the sales person responsible for this contact. Nullable so
  // contacts survive an owner's removal.
  ownerId  String?
  owner    User?   @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  name   String
  phone  String?
  email  String?
  source LeadSource @default(MANUAL)
  status LeadStatus @default(NEW)

  destination     String?
  travelStartDate DateTime?
  travelEndDate   DateTime?
  adults          Int       @default(1)
  children        Json?
  budget          Int?
  notes           String?
  nextFollowUpAt  DateTime?
  lostReason      String?
  // Household-level milestone — drives anniversary outreach. Individual
  // birthdays come from each Traveler's dateOfBirth.
  anniversary     DateTime?

  // Free-form service preferences (dietary, hotels, travel style, notes).
  preferences Json?
  // When this contact first became a paying customer (first booking).
  // NULL until then — its presence is what makes a contact a "customer".
  convertedAt DateTime?

  // Billing identity — used as the default recipient for tax invoices
  gstin            String?
  billingName      String?
  billingAddress   String?
  billingCity      String?
  billingState     String?
  billingStateCode String?
  billingPincode   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  trips            Trip[]
  travelers        Traveler[]
  activities       Activity[]
  tasks            Task[]
  whatsappMessages WhatsappMessage[]

  @@index([agencyId, status, nextFollowUpAt])
  @@index([agencyId, deletedAt])
  @@index([agencyId, ownerId])
  @@index([agencyId, convertedAt])
  @@index([phone])
}

/// An individual person who travels under a Contact. One Contact is a
/// household/account; its Travelers are the people on the passports —
/// primary contact, spouse, children, companions. Carries the
/// booking-critical identity an agency must hold: passport + expiry, visa,
/// DOB, dietary and seat/meal preferences, loyalty numbers.
model Traveler {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  fullName     String
  relationship TravelerRelationship @default(OTHER)
  // Exactly one traveler per contact should carry this — the account holder.
  isPrimary    Boolean              @default(false)

  dateOfBirth DateTime?
  gender      String?
  nationality String?

  // Passport / visa — the fields that gate international bookings.
  passportNumber       String?
  passportExpiry       DateTime?
  passportIssueCountry String?
  visaNotes            String?

  // Service preferences carried trip to trip.
  dietary String?
  // Loyalty program memberships: [{ program, number }]
  loyaltyNumbers Json?

  // Optional per-traveler contact overrides (else inherit from the contact).
  phone String?
  email String?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

model Trip {
  id       String  @id @default(cuid())
  agencyId String
  agency   Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  // Operations owner — the staffer responsible for executing this trip.
  // Often different from the sales person who closed it.
  ownerId  String?
  owner    User?   @relation("TripOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // The contact this trip is for. Nullable — a trip can stand alone and be
  // linked to a contact later.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  destination String
  days        Int
  travelers   Int
  startDate   DateTime?
  budget      Int?
  travelType  String    @default("Luxury")
  pace        String    @default("Moderate")
  hotelType   String    @default("Boutique")
  interests   String[]
  notes       String?

  status    TripStatus @default(PLANNING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  itineraries       Itinerary[]
  quotes            Quote[]
  bookings          Booking[]
  travelSegments    TravelSegment[]
  vendorAssignments VendorAssignment[]
  operationTasks    OperationTask[]
  vendorPayments    VendorPayment[]
  activities        Activity[]
  whatsappMessages  WhatsappMessage[]

  @@index([agencyId, createdAt])
  @@index([agencyId, ownerId])
  @@index([contactId])
  @@index([deletedAt])
}

model Itinerary {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  version   Int      @default(1)
  label     String?
  content   Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, version])
  @@index([tripId, isActive])
}

model Quote {
  id      String      @id @default(cuid())
  tripId  String
  trip    Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  version Int
  label   String?
  status  QuoteStatus @default(DRAFT)

  items        QuoteItem[]
  markupPct    Float       @default(15)
  discountPct  Float       @default(0)
  totalCost    Float       @default(0)
  sellingPrice Float       @default(0)
  profit       Float       @default(0)

  shareToken String?  @unique
  // Operator-only notes — never reaches the customer, used for haggle
  // boundaries, supplier reminders, internal context on each version.
  internalNotes String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking Booking?

  @@unique([tripId, version])
  @@index([tripId, status])
}

model QuoteItem {
  id       String @id @default(cuid())
  quoteId  String
  quote    Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  category String
  label    String
  cost     Float
  position Int    @default(0)

  @@index([quoteId])
}

model Booking {
  id                String             @id @default(cuid())
  tripId            String
  trip              Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  quoteId           String             @unique
  quote             Quote              @relation(fields: [quoteId], references: [id])
  status            BookingStatus      @default(PENDING)
  totalAmount       Float
  paidAmount        Float              @default(0)
  payments          Payment[]
  vendorAssignments VendorAssignment[]
  operationTasks    OperationTask[]
  vendorPayments    VendorPayment[]
  invoice           Invoice?
  whatsappMessages  WhatsappMessage[]
  paymentLinks      PaymentLink[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([tripId])
}

model Payment {
  id        String      @id @default(cuid())
  bookingId String
  booking   Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type      PaymentType
  amount    Float
  method    String?
  reference String?
  paidAt    DateTime    @default(now())

  @@index([bookingId])
}

/// An online payment-collection link (Razorpay Payment Link) sent to a
/// customer. On capture, the provider webhook records a Payment row against
/// the booking and flips this to PAID. Manual payments still use Payment
/// directly — this only models the "collect online" flow.
model PaymentLink {
  id        String  @id @default(cuid())
  agencyId  String
  agency    Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  amount      Float
  description String?
  status      PaymentLinkStatus @default(CREATED)

  // Provider details — currently Razorpay. providerLinkId is "plink_xxx";
  // providerPaymentId is the captured "pay_xxx" (audit + idempotency).
  provider          String    @default("razorpay")
  providerLinkId    String?   @unique
  shortUrl          String?
  providerPaymentId String?
  paidAt            DateTime?

  // The Payment row created when this link was paid (links the two).
  paymentId String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bookingId])
  @@index([agencyId, status])
}

model Activity {
  id        String       @id @default(cuid())
  contactId String?
  contact   Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      Trip?        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vendorId  String?
  vendor    Vendor?      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // Who performed the action — null for system / automation / webhook events.
  actorId   String?
  actor     User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  type      ActivityType
  title     String
  body      String?
  metadata  Json?
  createdAt DateTime     @default(now())

  @@index([contactId, createdAt])
  @@index([tripId, createdAt])
  @@index([vendorId, createdAt])
  @@index([invoiceId, createdAt])
}

model TravelSegment {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type      TravelSegmentType
  dayNumber Int               @default(1)

  from          String
  to            String
  departureTime DateTime
  arrivalTime   DateTime

  // Flight fields
  airline      String?
  flightNumber String?
  pnr          String?

  // Train fields
  trainName   String?
  trainNumber String?
  coach       String?
  seat        String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId, dayNumber])
}

model Task {
  id          String    @id @default(cuid())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title       String
  notes       String?
  dueAt       DateTime
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([completedAt, dueAt])
  @@index([contactId])
}

model Vendor {
  id       String     @id @default(cuid())
  agencyId String
  agency   Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name     String
  type     VendorType @default(OTHER)

  phone    String?
  whatsapp String?
  email    String?
  address  String?
  city     String?
  state    String?
  country  String?

  gstNumber    String?
  paymentTerms String?
  notes        String?

  isPreferred Boolean @default(false)
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignments VendorAssignment[]
  payments    VendorPayment[]
  activities  Activity[]

  @@index([agencyId, type, isActive, deletedAt])
  @@index([agencyId, city])
  @@index([deletedAt])
}

model VendorAssignment {
  id String @id @default(cuid())

  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Nullable — an assignment can be seeded from an accepted quote's line
  // items before a vendor has been sourced for it.
  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  category    VendorAssignmentCategory
  title       String
  description String?

  startDate DateTime?
  endDate   DateTime?

  quantity     Int?
  totalCost    Float?
  sellingPrice Float?

  confirmationNumber String?
  voucherSent        Boolean @default(false)
  customerVisible    Boolean @default(true)

  status VendorAssignmentStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vouchers Voucher[]

  @@index([tripId, status])
  @@index([vendorId, status])
  @@index([bookingId])
}

model Voucher {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   VendorAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  voucherNumber String @unique
  shareToken    String @unique
  title         String
  content       Json

  generatedAt   DateTime  @default(now())
  sentAt        DateTime?
  downloadCount Int       @default(0)

  @@index([assignmentId])
}

model OperationTask {
  id String @id @default(cuid())

  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  title       String
  description String?

  type     OperationTaskType     @default(OTHER)
  status   OperationTaskStatus   @default(PENDING)
  priority OperationTaskPriority @default(MEDIUM)

  dueDate     DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId, status])
  @@index([status, dueDate])
}

model VendorPayment {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  amount      Float
  paymentDate DateTime
  mode        VendorPaymentMode @default(BANK)
  reference   String?
  notes       String?

  createdAt DateTime @default(now())

  @@index([vendorId, paymentDate])
  @@index([tripId])
}

/// Per-agency identity + invoice configuration. Singleton per agency.
model AgencySettings {
  id       String @id @default(cuid())
  agencyId String @unique
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Identity
  legalName String
  tradeName String?
  gstin     String?
  pan       String?

  // Address (used as supplier on invoices)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  stateCode    String? // GST state code, e.g. "27" for Maharashtra
  pincode      String?
  country      String  @default("India")

  // Contact
  phone   String?
  email   String?
  website String?

  // Signatory shown on invoices
  authorizedSignatory  String?
  signatoryDesignation String?

  // Branding
  logoUrl String?

  // Invoice configuration
  invoicePrefix                 String           @default("TC")
  defaultTaxScheme              InvoiceTaxScheme @default(GST_5_NO_ITC)
  defaultTaxableBasis           TaxableBasis     @default(FULL_AMOUNT)
  defaultSacCode                String           @default("998552")
  defaultPlaceOfSupplyState     String?
  defaultPlaceOfSupplyStateCode String?

  // Optional bank details printed on invoice footer
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankAccountHolder String?

  // Free-text terms / notes shown on invoice footer
  invoiceTerms String?
  invoiceNotes String?

  // === Proposal / itinerary branding =======================================
  // How the customer-facing proposal page renders. All optional with
  // sensible defaults — the agency can ship without touching any of these.
  proposalTheme         String  @default("classic") // classic | editorial | minimal
  proposalAccentColor   String? // hex e.g. "#C8A96A" — overrides the sand accent
  proposalCoverStyle    String  @default("photo")   // photo | gradient | solid
  proposalShowAtAGlance Boolean @default(true)
  proposalShowInclusions Boolean @default(true)
  proposalShowTerms      Boolean @default(true)
  // Closing sign-off shown above the agency contact block.
  proposalSignatureNote  String?
  // Stamp the agency logo on every major section header.
  proposalRepeatLogo     Boolean @default(true)

  // === WhatsApp Cloud API (per-agency BYO credentials) ====================
  // The agency connects its own Meta WhatsApp Business account. Secret values
  // (access token, app secret) are stored encrypted at rest — see
  // [crypto.ts](src/lib/crypto.ts). Non-secret IDs are plaintext.
  waEnabled            Boolean @default(false)
  waPhoneNumberId      String?
  waBusinessAccountId  String?
  waApiVersion         String?
  waAccessTokenEnc     String? // encrypted
  waAppSecretEnc       String? // encrypted (used to verify inbound webhook signatures)
  waWebhookVerifyToken String? // agency-chosen handshake token (pasted into Meta)

  // === Payments — Razorpay (per-agency BYO credentials) ===================
  razorpayEnabled          Boolean @default(false)
  razorpayKeyId            String?
  razorpayKeySecretEnc     String? // encrypted
  razorpayWebhookSecretEnc String? // encrypted

  // Future-proof feature flags
  eInvoiceEnabled Boolean @default(false)
  eWayBillEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-agency, per-fiscal-year sequence allocator. Locked atomically on
/// invoice issue so numbers stay sequential and unique within the FY.
model InvoiceCounter {
  id           String @id @default(cuid())
  agencyId     String
  agency       Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  fiscalYear   String // e.g. "26-27"
  prefix       String // captured at first allocation; informational
  lastSequence Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, fiscalYear])
}

model Invoice {
  id          String  @id @default(cuid())
  agencyId    String
  agency      Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  // Who in the agency drafted/issued this — survives the user being removed.
  createdById String?
  createdBy   User?   @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  // Numbering — assigned at ISSUE; null for DRAFT
  invoiceNumber   String? @unique
  invoiceFy       String?
  invoiceSequence Int?

  status       InvoiceStatus @default(DRAFT)
  invoiceDate  DateTime      @default(now())
  issuedAt     DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  // GST regime selected for this invoice
  taxScheme    InvoiceTaxScheme @default(GST_5_NO_ITC)
  taxRatePct   Float            @default(5)
  taxableBasis TaxableBasis     @default(FULL_AMOUNT)

  // Place of supply (drives CGST+SGST vs IGST split)
  placeOfSupplyState     String?
  placeOfSupplyStateCode String?

  // Frozen snapshots so historical edits to agency / lead don't mutate issued docs
  supplierSnapshot  Json?
  recipientSnapshot Json?

  // Line items
  items InvoiceItem[]

  // Computed totals (denormalized for display + reporting)
  subtotal      Float   @default(0)
  cgstAmount    Float   @default(0)
  sgstAmount    Float   @default(0)
  igstAmount    Float   @default(0)
  taxTotal      Float   @default(0)
  roundOff      Float   @default(0)
  grandTotal    Float   @default(0)
  amountInWords String?

  // Public share token (for the recipient to view/download online)
  shareToken String? @unique

  activities       Activity[]
  whatsappMessages WhatsappMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, invoiceFy, invoiceSequence])
  @@index([agencyId, status])
  @@index([agencyId, invoiceFy])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  position    Int    @default(0)
  description String
  sacCode     String // SAC for services (HSN repurposed for goods if ever needed)

  quantity  Float @default(1)
  unitPrice Float @default(0)

  // Used only when invoice.taxableBasis = MARGIN_ONLY
  cost Float?

  // Computed by the tax service when invoice is built / regenerated
  taxableValue Float @default(0)
  taxRatePct   Float @default(5)
  cgstAmount   Float @default(0)
  sgstAmount   Float @default(0)
  igstAmount   Float @default(0)

  @@index([invoiceId])
}

/// One WhatsApp message — inbound or outbound. Acts as both the queue
/// record (status QUEUED before dispatch) and the historical ledger.
/// `whatsappMessageId` is the Meta-issued wamid and is the idempotency key
/// for webhook status updates.
model WhatsappMessage {
  id String @id @default(cuid())

  agencyId     String
  agency       Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  // Operator who triggered this send (null for inbound).
  sentByUserId String?
  sentByUser   User?   @relation("WhatsappSender", fields: [sentByUserId], references: [id], onDelete: SetNull)

  // Optional links — any of these can be set so the message timelines
  // against the right CRM entity. Storing all of them keeps queries simple.
  contactId  String?
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  tripId     String?
  trip       Trip?     @relation(fields: [tripId], references: [id], onDelete: SetNull)
  invoiceId  String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  bookingId  String?
  booking    Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  kind      WhatsappMessageKind @default(TEXT)
  direction WhatsappDirection
  status    WhatsappStatus      @default(QUEUED)

  templateName  String?
  templateId    String?
  // E.164 with no '+' (Meta's expected wire format), e.g. "919876543210"
  phone         String
  message       String  @db.Text
  mediaUrl      String?
  mediaFilename String?

  // Free-form: template variables, conversation context, button payloads,
  // pricing categories, automation trigger that scheduled this, etc.
  metadata Json?

  // Meta wamid — unique once we have it.
  whatsappMessageId String? @unique

  // Idempotency on outbound. Hash of (userId|phone|template|payload|day)
  // so retries don't double-send. Nullable for inbound.
  idempotencyKey String?

  // Scheduled dispatch time — null means "send immediately".
  scheduledFor DateTime?
  attempts     Int       @default(0)

  // Automation provenance (when a rule produced this message).
  automationRuleId String?
  automationRule   WhatsappAutomationRule? @relation(fields: [automationRuleId], references: [id], onDelete: SetNull)

  // Inbound conversation linking — pointer to the outbound message this
  // is replying to (best effort, used for thread rendering).
  replyToId String?
  replyTo   WhatsappMessage?  @relation("WhatsappMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   WhatsappMessage[] @relation("WhatsappMessageReply")

  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  failedCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, idempotencyKey])
  @@index([agencyId, status, scheduledFor])
  @@index([agencyId, phone, createdAt])
  @@index([agencyId, direction, createdAt])
  @@index([contactId, createdAt])
  @@index([tripId, createdAt])
  @@index([invoiceId, createdAt])
  @@index([bookingId, createdAt])
  @@index([automationRuleId, createdAt])
}

/// Reusable Meta-approved template registry. `templateId` mirrors the
/// Meta template name as it must be referenced when sending.
model WhatsappTemplate {
  id String @id @default(cuid())

  agencyId    String
  agency      Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?   @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  name     String // display name (internal)
  category WhatsappTemplateCategory @default(CUSTOM)
  language String                   @default("en")

  // Name registered with Meta (snake_case). The send API references this.
  templateId String

  // Ordered list of variable definitions: { key, label, example }
  variables Json

  // Local preview body — Meta-approved canonical body lives on Meta's side,
  // this is the editor preview text. Variables use {{name}} placeholders.
  bodyPreview String @db.Text

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  automationRules WhatsappAutomationRule[]

  @@unique([agencyId, templateId, language])
  @@index([agencyId, category, isActive])
}

/// Trigger → template binding. The automation runner scans the relevant
/// domain (quotes, payments, trips) for entities matching `trigger` and
/// enqueues outbound messages.
model WhatsappAutomationRule {
  id String @id @default(cuid())

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  trigger    WhatsappAutomationTrigger
  templateId String
  template   WhatsappTemplate          @relation(fields: [templateId], references: [id], onDelete: Restrict)

  enabled      Boolean @default(true)
  // Additional offset *after* the canonical trigger window fires.
  delayMinutes Int     @default(0)

  // Free-form policy bag (quiet hours, target lead statuses, max attempts).
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsappMessage[]

  @@unique([agencyId, trigger])
  @@index([agencyId, enabled])
}
